# Template Dockerfile FastAPI — adaptar main:app e APP_PORT após perguntar ao usuário (rule 130).
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# Invalida cache do BuildKit no runner self-hosted a cada commit (evita COPY . . stale).
ARG CACHE_BUST
RUN test -n "${CACHE_BUST}"

COPY . .

# APP_PORT: definir após perguntar ao usuário — não assumir 8000/8010.
ARG APP_PORT={APP_PORT}
EXPOSE ${APP_PORT}

CMD ["sh", "-c", "gunicorn {ASGI_MODULE} -c gunicorn_conf.py -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:${APP_PORT} --workers 4 --timeout 60"]
