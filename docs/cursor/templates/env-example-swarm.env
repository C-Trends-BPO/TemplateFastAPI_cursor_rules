# =============================================================================
# {Nome Projeto} — variáveis de ambiente (produção Docker Swarm)
#
# Copiar para o servidor (NUNCA versionar o .env real):
#   /opt/envs/{nome-app}.env
#   sudo chmod 600 /opt/envs/{nome-app}.env
#   sudo chown root:root /opt/envs/{nome-app}.env
#
# Perguntar APP_PORT ao time antes de definir — não assumir 8000/8010.
# =============================================================================

# --- Aplicação ---
APP_ENV=production
APP_PORT=
SECRET_KEY=changeme
ALLOWED_ORIGINS=https://www.exemplo.com.br

# --- Banco / cache (fora do container) ---
DATABASE_URL=postgresql+asyncpg://user:password@192.168.0.220:5432/dbname
REDIS_URL=redis://192.168.0.220:6379/0

# --- Imagem (preenchido pelo workflow; manter vazio no servidor se o deploy exporta IMAGE) ---
# IMAGE=ghcr.io/org/repo:sha

# --- Observabilidade (Swarm: sem sufixo de IP; OTEL init no post_fork do Gunicorn) ---
OTEL_ENABLED=True
OTEL_SERVICE_NAME=NomeAplicacaoFastAPI
OTEL_APPEND_ENV=True
OTEL_APPEND_IP_SUFFIX=False
OTEL_DEFER_INIT=True
OTEL_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.0.213:4318
LOKI_ENABLED=True
LOKI_APP_NAME=NomeAplicacaoFastAPI
LOKI_URL=http://192.168.0.213:3100/loki/api/v1/push
LOG_LEVEL=INFO
ENABLE_TEST_ROUTES=False
