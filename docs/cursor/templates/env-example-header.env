# =============================================================================
# {Nome Projeto} — variáveis de ambiente (produção)
# Copie para .env: Copy-Item .env.example .env
#
# Use aspas em senhas/segredos com #, $, espaços ou = no valor.
# Ex.: PSQL_PASSWORD="senha#com-caracteres-especiais"
# =============================================================================

# --- API ---
DEBUG=false
API_V1_STR=/api
ROOT_PATH=/api-{nome-projeto}
PROJECT_NAME={Nome Projeto}

# --- Banco principal (adaptar prefixos PSQL_* / SQL_* do projeto) ---
PSQL_HOST=192.168.0.220
PSQL_USER=your-db-user
PSQL_PASSWORD="your-db-password"
PSQL_DATABASE=your_database
PSQL_PORT=5432

# --- Testes de integração (homologação) ---
INTEGRATION_TEST_USERNAME=
INTEGRATION_TEST_PASSWORD=

# =============================================================================
# Homologação — perfil alternativo (.env)
# =============================================================================
# DEBUG=true
# ROOT_PATH=/hg-api-{nome-projeto}
# PROJECT_NAME=Homologação {Nome Projeto}
# PSQL_HOST=192.168.0.219
# PSQL_USER=your-db-user
# PSQL_PASSWORD="your-db-password"
# PSQL_DATABASE=your_database
# PSQL_PORT=5432
#
# Debug: .vscode/launch.json — ver rule 085-fastapi-env-debug-manual.mdc
# =============================================================================
